    def start_worker(self):
        if self.worker and self.worker.isRunning():
            return
        try:
            thresholds = {
                'far_left': self.sl_far_left.value(),
                'soft_left': self.sl_soft_left.value(),
                'center_min': self.sl_center_min.value(),
                'center_max': self.sl_center_max.value(),
                'soft_right': self.sl_soft_right.value(),
                'far_right': self.sl_far_right.value(),
            }
            # zone key map
            zone_keymap = {
                'FAR_LEFT': self.combo_to_scan(self.cb_far_left.currentText()),
                'SOFT_LEFT': self.combo_to_scan(self.cb_soft_left.currentText()),
                'CENTER': self.combo_to_scan(self.cb_center.currentText()),
                'SOFT_RIGHT': self.combo_to_scan(self.cb_soft_right.currentText()),
                'FAR_RIGHT': self.combo_to_scan(self.cb_far_right.currentText()),
            }

            self.worker = TrackingWorker(zone_thresholds=thresholds, zone_keymap=zone_keymap,
                             smoothing_window=self.sl_smoothing.value(),
                             tap_duration_ms=self.sl_tap_duration.value())
            self.worker.image_signal.connect(self.update_image)
            self.worker.yaw_signal.connect(self.on_yaw)
            self.worker.zone_signal.connect(self.on_zone)
            self.worker.status_signal.connect(self.on_status)
            self.worker.calibrated_signal.connect(self.on_calibrated)
            # ensure UI remains responsive: do not block on wait(); connect finished
            self.worker.finished.connect(self.on_worker_finished)
            self.worker.start()
            self.status_label.setText('Status: Running')
            self.btn_start.setEnabled(False)
            self.btn_stop.setEnabled(True)
        except Exception as exc:
            self.status_label.setText('Status: Start failed')
            QMessageBox.critical(self, 'Start Error', str(exc))

    def stop_worker(self):
        if self.worker:
            self.worker.stop()
            # don't block GUI thread; cleanup handled in on_worker_finished
            self.status_label.setText('Status: Stopping...')
            self.btn_start.setEnabled(True)
            self.btn_stop.setEnabled(False)


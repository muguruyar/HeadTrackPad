# DirectInput Hardware Scan Codes (Numpad tuşları)
SCAN_CODES = {
    'NUM_4': 0x4B,   # Numpad 4
    'NUM_7': 0x47,   # Up-Left (Hafif Sol)
    'NUM_5': 0x4C,   # Center (Merkez)
    'NUM_9': 0x49,   # Up-Right (Hafif Sağ)
    'NUM_6': 0x4D,   # Numpad 6
}

# Bölge tanımları
class GameZone(Enum):
    """Yaw açısına göre oyun bölgeleri"""
    FAR_LEFT = ('NUM_4', -90, -40, "En Sol")      # Yaw < -40°
    SOFT_LEFT = ('NUM_7', -40, -15, "Hafif Sol")  # -40° ≤ Yaw < -15°
    CENTER = ('NUM_5', -15, 15, "Merkez")         # -15° ≤ Yaw ≤ 15° [DEADZONE]
    SOFT_RIGHT = ('NUM_9', 15, 40, "Hafif Sağ")   # 15° < Yaw ≤ 40°
    FAR_RIGHT = ('NUM_6', 40, 90, "En Sağ")       # Yaw > 40°


class DirectInputKeyboard:
    """
    Windows API ve DirectInput Hardware Scan Codes kullanarak tuş kontrolü
    ctypes aracılığıyla kernel seviyesinde çalışır
    """
    
    def __init__(self):
        """Windows API'ye erişimi başlat"""
        self.user32 = ctypes.windll.user32
        self.kernel32 = ctypes.windll.kernel32
        
        # Keyboard event flags
        self.KEYEVENTF_SCANCODE = 0x0008
        self.KEYEVENTF_KEYUP = 0x0002
        self.KEYEVENTF_EXTENDEDKEY = 0x0001

        # Proper Win32 INPUT structs for SendInput (ctypes)
        self.INPUT_KEYBOARD = 1
        self.PUL = ctypes.POINTER(ctypes.c_ulong)

        class KEYBDINPUT(ctypes.Structure):
            _fields_ = [
                ("wVk", wintypes.WORD),
                ("wScan", wintypes.WORD),
                ("dwFlags", wintypes.DWORD),
                ("time", wintypes.DWORD),
                ("dwExtraInfo", self.PUL),
            ]

        class INPUTUNION(ctypes.Union):
            _fields_ = [("ki", KEYBDINPUT)]

        class INPUT(ctypes.Structure):
            _fields_ = [
                ("type", wintypes.DWORD),
                ("u", INPUTUNION),
            ]

        self.KEYBDINPUT = KEYBDINPUT
        self.INPUTUNION = INPUTUNION
        self.INPUT = INPUT

        self.user32.SendInput.argtypes = (wintypes.UINT, ctypes.POINTER(self.INPUT), ctypes.c_int)
        self.user32.SendInput.restype = wintypes.UINT
        # GetLastError is in kernel32, not user32
        self.kernel32.GetLastError.argtypes = ()
        self.kernel32.GetLastError.restype = wintypes.DWORD
        self.verbose_errors = False
    
    def send_key_event(self, scan_code, is_key_down=True):
        """
        DirectInput hardware scan code ile tuş gönder
        
        Args:
            scan_code (int): Hardware scan code (0x4A, 0x47, vb.)
            is_key_down (bool): True = KeyDown, False = KeyUp
        """
        flags = self.KEYEVENTF_SCANCODE
        if not is_key_down:
            flags |= self.KEYEVENTF_KEYUP

        ki = self.KEYBDINPUT(
            wVk=0,
            wScan=int(scan_code),
            dwFlags=flags,
            time=0,
            dwExtraInfo=ctypes.pointer(ctypes.c_ulong(0)),
        )
        inp = self.INPUT(type=self.INPUT_KEYBOARD, u=self.INPUTUNION(ki=ki))
        arr = (self.INPUT * 1)(inp)

        sent = self.user32.SendInput(1, arr, ctypes.sizeof(self.INPUT))
        if sent == 1:
            return

        # Fallback path: try keybd_event with the same scancode if SendInput fails.
        try:
            self.user32.keybd_event(0, scan_code, flags, 0)
            return
        except Exception:
            pass

        if self.verbose_errors:
            err = self.kernel32.GetLastError()
            print(f"[HATA] Key send failed. scan={scan_code}, down={is_key_down}, err={err}")


class SmoothingFilter:
    """
    Açı verilerini yumuşatmak için Moving Average (Hareketli Ortalama) filtresi
    Ani sıçramaları ve tremor'u engeller
    """
    
    def __init__(self, window_size=5):
        """
        Args:
            window_size (int): Ortalama için kullanılacak veri noktası sayısı
        """
        self.window_size = window_size
        self.buffer = deque(maxlen=window_size)
    
    def apply(self, value):
        """
        Değeri filtrele ve pürüzsüzleştirilmiş sonuç dön
        
        Args:
            value (float): Ham açı değeri
        
        Returns:
            float: Filtreli açı değeri
        """
        self.buffer.append(value)
        if len(self.buffer) > 0:
            return float(np.mean(self.buffer))
        return float(value)


class FaceHeadDetector:
    """
    MediaPipe Face Mesh kullanarak yüz tespiti ve Yaw açı hesaplaması
    """
    
    def __init__(self):
        try:
            import mediapipe as mp
            # prefer solutions.face_mesh
            if hasattr(mp, 'solutions') and hasattr(mp.solutions, 'face_mesh'):
                self.mp_face_mesh = mp.solutions.face_mesh
                self.face_mesh = self.mp_face_mesh.FaceMesh(
                    static_image_mode=False,
                    max_num_faces=1,
                    min_detection_confidence=0.7,
                    min_tracking_confidence=0.7
                )
            else:
                # fallback for tasks API
                from mediapipe.tasks import python as mp_python
                from mediapipe.tasks.python import vision
                self.mp_face_mesh = vision
                # tasks API usage differs; in many envs solutions exist, so keep a minimal fallback
                self.face_mesh = None
                print('[UYARI] MediaPipe tasks API detected; FaceMesh instance not created.')
        except Exception as e:
            raise ImportError('MediaPipe yüklenemedi. Lütfen: pip install mediapipe') from e
    
    def calculate_yaw_angle(self, landmarks, frame_width, frame_height):
        """
        Yaw açısını hesapla: Yüz mesh landmark'larından yatay dönüş açısı
        
        Landmark 1 = Burun ucu
        Landmark 33 = Sol göz
        Landmark 263 = Sağ göz
        
        Burun merkezi ile göz merkezi arası mesafe => Yaw açı
        
        Args:
            landmarks: Face Mesh landmarks (468 nokta)
            frame_width (int): Video çerçevesi genişliği
            frame_height (int): Video çerçevesi yüksekliği
        
        Returns:
            float: Yaw açı (-90 ila 90 derece, - = sol, + = sağ)
        """
        try:
            # Landmark indexleri
            NOSE_TIP = 1
            LEFT_EYE = 33
            RIGHT_EYE = 263
            
            # Normalized koordinatları pixel koordinatlarına çevir
            nose = np.array([
                landmarks[NOSE_TIP].x * frame_width,
                landmarks[NOSE_TIP].y * frame_height
            ])
            
            left_eye = np.array([
                landmarks[LEFT_EYE].x * frame_width,
                landmarks[LEFT_EYE].y * frame_height
            ])
            
            right_eye = np.array([
                landmarks[RIGHT_EYE].x * frame_width,
                landmarks[RIGHT_EYE].y * frame_height
            ])
            
            # Göz merkezi
            eye_center = (left_eye + right_eye) / 2.0
            
            # Burun ile göz merkezi arasındaki yatay açı (delta X)
            dx = nose[0] - eye_center[0]
            
            # Normalize et: -1 ile 1 arasına, sonra -90 ile 90 derecesine çevir
            max_displacement = frame_width / 3.5  # Empirik değer
            yaw_normalized = np.clip(dx / max_displacement, -1.0, 1.0)
            yaw_angle = yaw_normalized * 90.0
            
            return yaw_angle
        
        except Exception as e:
            print(f"[HATA] Yaw açı hesaplamada sorun: {e}")
            return 0.0
    
    def detect_and_calculate(self, frame):
        """
        Çerçevede yüz tespit et ve Yaw açısını hesapla
        
        Args:
            frame: OpenCV frame (BGR)
        
        Returns:
            tuple: (yaw_angle, landmarks, face_detected)
        """
        frame_height, frame_width, _ = frame.shape
        if self.face_mesh is None:
            return 0.0, None, False

        frame_rgb = cv2.cvtColor(frame, cv2.COLOR_BGR2RGB)
        results = self.face_mesh.process(frame_rgb)

        if results.multi_face_landmarks and len(results.multi_face_landmarks) > 0:
            landmarks = results.multi_face_landmarks[0].landmark
            yaw = self.calculate_yaw_angle(landmarks, frame_width, frame_height)
            return yaw, landmarks, True

        return 0.0, None, False
    
    def close(self):
        """MediaPipe kaynaklarını serbest bırak"""
        if hasattr(self, 'face_mesh'):
            try:
                self.face_mesh.close()
            except Exception:
                pass



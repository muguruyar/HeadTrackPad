class TrackingWorker(QThread):
    image_signal = pyqtSignal(QImage)
    yaw_signal = pyqtSignal(float)
    zone_signal = pyqtSignal(str)
    status_signal = pyqtSignal(str)
    calibrated_signal = pyqtSignal(float)

    def __init__(self, zone_thresholds=None, zone_keymap=None, smoothing_window=5, tap_duration_ms=10, parent=None):
        super().__init__(parent=parent)
        self.detector = FaceHeadDetector()
        self.keyboard = DirectInputKeyboard()
        self.smoothing = SmoothingFilter(window_size=smoothing_window)

        # Video capture
        self.cap = cv2.VideoCapture(0)
        self.cap.set(cv2.CAP_PROP_FRAME_WIDTH, 640)
        self.cap.set(cv2.CAP_PROP_FRAME_HEIGHT, 480)
        self.cap.set(cv2.CAP_PROP_FPS, 30)

        # Dynamic thresholds (degrees)
        self.zone_thresholds = zone_thresholds or {
            'far_left': -12,
            'soft_left': -7,
            'center_min': -6,
            'center_max': 6,
            'soft_right': 12,
            'far_right': 20,
        }

        # Key mapping: zone name -> scan code
        default_map = {
            'FAR_LEFT': SCAN_CODES['NUM_4'],
            'SOFT_LEFT': SCAN_CODES['NUM_7'],
            'CENTER': SCAN_CODES['NUM_5'],
            'SOFT_RIGHT': SCAN_CODES['NUM_9'],
            'FAR_RIGHT': SCAN_CODES['NUM_6'],
        }
        self.zone_keymap = zone_keymap or default_map

        # State machine
        self.current_zone = None
        self.key_pressed = False
        self.current_scan = None

        # Control flags
        self.running = True
        self.send_keys_enabled = True
        self.preview_enabled = True
        self.calibration_offset = 0.0
        self.calibration_requested = False
        self.calibrating = False
        self.debug_keys = False
        self.tap_duration_ms = int(tap_duration_ms)

    def run(self):
        self.status_signal.emit('started')
        while self.running:
            ret, frame = self.cap.read()
            if not ret:
                self.status_signal.emit('camera_error')
                break

            frame = cv2.flip(frame, 1)
            raw_yaw, landmarks, face_detected = self.detector.detect_and_calculate(frame)

            # If calibration requested, perform it inside worker thread using raw yaw samples.
            if self.calibration_requested:
                self._perform_calibration()

            if face_detected:
                # apply calibration offset
                yaw_adj = raw_yaw - self.calibration_offset
                smoothed = self.smoothing.apply(yaw_adj)

                zone = self.get_zone_from_angle(smoothed)
                self.handle_zone_change(zone)

                # Emit status
                self.yaw_signal.emit(smoothed)
                self.zone_signal.emit(zone.name)

                # Emit image if preview enabled
                if self.preview_enabled:
                    qimg = self.cv_frame_to_qimage(frame)
                    self.image_signal.emit(qimg)
            else:
                # face not found -> release keys
                self.release_all_keys()
                if self.preview_enabled:
                    qimg = self.cv_frame_to_qimage(frame)
                    self.image_signal.emit(qimg)

            time.sleep(0.01)

        # cleanup
        try:
            self.cap.release()
        except Exception:
            pass
        self.detector.close()
        self.status_signal.emit('stopped')

    def stop(self):
        self.running = False
        # ensure keys released
        self.release_all_keys()

    def cv_frame_to_qimage(self, frame):
        rgb = cv2.cvtColor(frame, cv2.COLOR_BGR2RGB)
        h, w, ch = rgb.shape
        bytes_per_line = ch * w
        qimg = QImage(rgb.data, w, h, bytes_per_line, QImage.Format.Format_RGB888)
        return qimg.copy()

    def get_zone_from_angle(self, yaw_angle):
        """Zone classification with hysteresis to prevent flickering.
        
        Entry: Strict thresholds (normal boundaries).
        Exit: Looser thresholds (stay in zone until crossing back past center boundary).
        """
        t = self.zone_thresholds
        current = self.current_zone
        
        # ============ LEFT SIDE ============
        
        # FAR_LEFT: Enter at far_left, exit only when passing beyond soft_left
        if current == GameZone.FAR_LEFT:
            if yaw_angle > t['soft_left']:
                return GameZone.SOFT_LEFT  # Exit FAR_LEFT
            return GameZone.FAR_LEFT  # Stay FAR_LEFT
        
        if yaw_angle < t['far_left']:
            return GameZone.FAR_LEFT
        
        # SOFT_LEFT: Enter at soft_left, exit only when passing beyond center_min
        if current == GameZone.SOFT_LEFT:
            if yaw_angle > t['center_min']:
                return GameZone.CENTER  # Exit SOFT_LEFT
            return GameZone.SOFT_LEFT  # Stay SOFT_LEFT
        
        if yaw_angle <= t['soft_left']:
            return GameZone.SOFT_LEFT
        
        # ============ CENTER ============
        # Center is the safe zone; stay here unless clearly entering left or right
        
        # Check right side first (for entering SOFT_RIGHT)
        if current == GameZone.SOFT_RIGHT:
            # Stay in SOFT_RIGHT until yaw drops below center_max
            if yaw_angle <= t['center_max']:
                return GameZone.CENTER
            if yaw_angle < t['far_right']:
                return GameZone.SOFT_RIGHT
            return GameZone.FAR_RIGHT
        
        if current == GameZone.FAR_RIGHT:
            # Stay in FAR_RIGHT until yaw drops below soft_right
            if yaw_angle < t['soft_right']:
                return GameZone.SOFT_RIGHT
            return GameZone.FAR_RIGHT
        
        # If not in a right zone, check if we should enter right side
        if yaw_angle >= t['soft_right']:
            if yaw_angle >= t['far_right']:
                return GameZone.FAR_RIGHT
            return GameZone.SOFT_RIGHT
        
        # Default: CENTER zone (safe zone between left and right)
        return GameZone.CENTER

    def handle_zone_change(self, new_zone):
        if new_zone != self.current_zone:
            # tap new key once; do not hold it
            new_scan = self.zone_keymap.get(new_zone.name, None)
            if new_scan and self.send_keys_enabled:
                if self.debug_keys:
                    print(f"[TAP] {new_zone.name} scan={new_scan}")
                self.keyboard.send_key_event(new_scan, is_key_down=True)
                time.sleep(max(self.tap_duration_ms, 1) / 1000.0)
                self.keyboard.send_key_event(new_scan, is_key_down=False)
                self.current_scan = new_scan

            self.current_zone = new_zone
            self.key_pressed = False

    def release_all_keys(self):
        # Keys are not held anymore, only reset state.
        self.key_pressed = False
        self.current_zone = None

    def set_smoothing(self, window_size):
        # re-init smoother buffer
        self.smoothing = SmoothingFilter(window_size=window_size)

    def set_tap_duration(self, tap_duration_ms):
        self.tap_duration_ms = max(1, int(tap_duration_ms))

    def calibrate(self, current_yaw):
        self.calibration_offset = current_yaw

    def request_calibration(self):
        self.calibration_requested = True

    def _perform_calibration(self):
        # Avoid re-entrant calibration
        if self.calibrating:
            return

        self.calibrating = True
        self.calibration_requested = False

        samples = []
        max_frames = 18
        needed = 10

        for _ in range(max_frames):
            if not self.running:
                break
            ret, frame = self.cap.read()
            if not ret:
                continue
            frame = cv2.flip(frame, 1)
            raw_yaw, _, face_detected = self.detector.detect_and_calculate(frame)
            if face_detected:
                samples.append(float(raw_yaw))
                if len(samples) >= needed:
                    break
            time.sleep(0.005)

        if samples:
            # robust center estimate to reduce instant noise/drift
            self.calibration_offset = float(np.median(samples))
            # reset smoothing buffer so old values do not pull yaw away from 0
            self.smoothing = SmoothingFilter(window_size=self.smoothing.window_size)
            # clear zone state so next frame can re-evaluate from the new center point
            self.current_zone = None
            self.current_scan = None
            self.key_pressed = False
            self.calibrated_signal.emit(0.0)
        else:
            self.calibrated_signal.emit(0.0)

        self.calibrating = False

    def update_threshold(self, key, value):
        # key in one of zone_thresholds
        self.zone_thresholds[key] = value

    def update_zone_key(self, zone_name, scan_code):
        self.zone_keymap[zone_name] = scan_code


class HeadTrackingGameController:
    """
    State Machine tabanlı Head Tracking oyun kontrol sistemi
    
    Özellikler:
    - Tuş spamlama önleme (State Machine)
    - Açı yumuşatma (Smoothing)
    - 5 bölge sistem
    - Kernel seviyesi DirectInput tuş kontrolü
    """
    
    def __init__(self):
        """Sistemi başlat"""
        self.detector = FaceHeadDetector()
        self.keyboard = DirectInputKeyboard()
        self.smoother = SmoothingFilter(window_size=5)
        
        # State tracking
        self.current_zone = None
        self.previous_zone = None
        self.key_currently_pressed = False
        self.current_scan_code = None
        
        # Video capture
        self.cap = cv2.VideoCapture(0)
        self.cap.set(cv2.CAP_PROP_FRAME_WIDTH, 640)
        self.cap.set(cv2.CAP_PROP_FRAME_HEIGHT, 480)
        self.cap.set(cv2.CAP_PROP_FPS, 30)
        
        # Uygulamayı eksekuter kontrol flag'ı
        self.app_running = True
        
        # İstatistikler
        self.frame_count = 0
        self.fps = 0.0
        self.last_time = time.time()
    
    def get_zone_from_angle(self, yaw_angle):
        """
        Yaw açısına göre bölgeyi belirle
        
        Args:
            yaw_angle (float): Derece cinsinden Yaw açı
        
        Returns:
            GameZone: Belirlenen bölge
        """
        for zone in GameZone:
            key_name, min_angle, max_angle, display_name = zone.value
            if min_angle <= yaw_angle <= max_angle:
                return zone
        
        # Fallback (abnormal case)
        return GameZone.CENTER
    
    def handle_zone_change(self, new_zone):
        """
        State Machine: Bölge değişimi handle et ve tuşları kontrol et
        
        Mantık:
        1. Yeni bölgeye girildiğinde: KeyDown gönder
        2. Bölgede kalındığında: Tuş basılı tut (tekrar gönderme)
        3. Bölgeden çıkıldığında: KeyUp gönder
        
        Args:
            new_zone (GameZone): Yeni bölge
        """
        # Bölge değişti mi?
        if new_zone != self.current_zone:
            # Önceki tuşu release et
            if self.current_zone is not None and self.key_currently_pressed:
                old_scan_code = SCAN_CODES[self.current_zone.value[0]]
                self.keyboard.send_key_event(old_scan_code, is_key_down=False)
                self.key_currently_pressed = False
            
            # Yeni tuş basılı tut
            new_scan_code = SCAN_CODES[new_zone.value[0]]
            self.keyboard.send_key_event(new_scan_code, is_key_down=True)
            self.key_currently_pressed = True
            
            self.current_zone = new_zone
            self.current_scan_code = new_scan_code
    
    def release_all_keys(self):
        """Tuş sıkışması olması durumunda tüm tuşları serbest bırak"""
        if self.key_currently_pressed and self.current_zone is not None:
            self.keyboard.send_key_event(self.current_scan_code, is_key_down=False)
            self.key_currently_pressed = False
            self.current_zone = None
    
    def process_frame(self, frame):
        """
        Çerçeveyi işle: Yüz detect => Yaw hesapla => Yumuşat => State update
        
        Args:
            frame: OpenCV frame
        
        Returns:
            tuple: (processed_frame, yaw_angle)
        """
        # Yüz algılama
        raw_yaw, landmarks, face_detected = self.detector.detect_and_calculate(frame)
        
        if face_detected:
            # Açı yumuşatma
            smoothed_yaw = self.smoother.apply(raw_yaw)
            
            # Bölge belirle ve tuş state'ini güncelle
            new_zone = self.get_zone_from_angle(smoothed_yaw)
            self.handle_zone_change(new_zone)
            
            # Görselleştirme: Landmark'ları çiz
            frame_height, frame_width, _ = frame.shape
            for i, landmark in enumerate(landmarks):
                if i % 15 == 0:  # Her 15. landmark'ı çiz (performans)
                    x = int(landmark.x * frame_width)
                    y = int(landmark.y * frame_height)
                    cv2.circle(frame, (x, y), 2, (0, 255, 0), -1)
            
            # Bilgi panel
            zone_name = self.current_zone.value[3] if self.current_zone else "YOK"
            key_name = self.current_zone.value[0] if self.current_zone else "---"
            
            cv2.putText(frame, f"Bolge: {zone_name}", (10, 30),
                       cv2.FONT_HERSHEY_SIMPLEX, 0.8, (0, 255, 0), 2)
            cv2.putText(frame, f"Tus: {key_name}", (10, 70),
                       cv2.FONT_HERSHEY_SIMPLEX, 0.8, (0, 255, 0), 2)
            cv2.putText(frame, f"Yaw: {smoothed_yaw:.1f}°", (10, 110),
                       cv2.FONT_HERSHEY_SIMPLEX, 0.8, (0, 255, 0), 2)
            cv2.putText(frame, f"FPS: {self.fps:.1f}", (10, 150),
                       cv2.FONT_HERSHEY_SIMPLEX, 0.8, (0, 255, 0), 2)
            
            return frame, smoothed_yaw
        
        else:
            # Yüz algılanamadı => tuşları serbest bırak
            self.release_all_keys()
            
            cv2.putText(frame, "YUZ ALGILANAMADI", (150, 240),
                       cv2.FONT_HERSHEY_SIMPLEX, 1.2, (0, 0, 255), 2)
            
            return frame, None
    
    def update_fps(self):
        """FPS'i hesapla"""
        self.frame_count += 1
        current_time = time.time()
        elapsed = current_time - self.last_time
        
        if elapsed >= 1.0:
            self.fps = self.frame_count / elapsed
            self.frame_count = 0
            self.last_time = current_time
    
    def print_config(self):
        """Bölge konfigürasyonunu konsola yazdır"""
        print("\n" + "="*70)
        print("  HEAD TRACKING OYUN KONTROLÜ - BAŞLATILDI")
        print("="*70)
        print("\n[BÖLGE KONFIGÜRASYONU]")
        for zone in GameZone:
            key, min_a, max_a, display = zone.value
            print(f"  {key:6} : {display:15} ({min_a:+3.0f}° ~ {max_a:+3.0f}°)")
        
        print("\n[KONTROL]")
        print("  'q' tuşu  : Uygulamayı kapat")
        print("  Space     : Kaynakları serbest bırak (acil durum)")
        
        print("\n[SİSTEM BİLGİSİ]")
        print("  Tuş Kontrolü : ctypes + DirectInput Hardware Scan Codes")
        print("  Yüz Algılama : MediaPipe Face Mesh")
        print("  Filtre       : Moving Average (5 noktası)")
        print("  State Machine: Tuş spamlama önleme [AKTIF]")
        print("\n" + "="*70 + "\n")
    
    def run(self):
        """Ana uygulama döngüsü"""
        self.print_config()
        
        try:
            while self.app_running:
                ret, frame = self.cap.read()
                if not ret:
                    print("[HATA] Kamera çerçevesi alınamadı")
                    break
                
                # Ayna görünümü (selfie modu)
                frame = cv2.flip(frame, 1)
                
                # Çerçeveyi işle
                processed_frame, yaw = self.process_frame(frame)
                
                # FPS'i güncelle
                self.update_fps()
                
                # Ekranda göster
                cv2.imshow("Head Tracking", processed_frame)
                
                # Tuş kontrolü
                key = cv2.waitKey(1) & 0xFF
                if key == ord('q'):
                    print("[INFO] Çıkış komutu alındı")
                    self.app_running = False
                elif key == ord(' '):
                    print("[INFO] Acil durum: Tüm tuşlar serbest bırakılıyor")
                    self.release_all_keys()
                
                # CPU'yu aşırı yüklememiş
                time.sleep(0.001)
        
        except KeyboardInterrupt:
            print("\n[INFO] Ctrl+C ile durduruldu")
        
        except Exception as e:
            print(f"\n[HATA] Beklenmeyen hata: {e}")
            import traceback
            traceback.print_exc()
        
        finally:
            self.cleanup()
    
    def cleanup(self):
        """Kaynakları temizle ve serbest bırak"""
        print("\n[CLEANUP] Sistem kapatılıyor...")
        
        # Tuş sıkışmasını önle
        self.release_all_keys()
        
        # Kaynakları serbest bırak
        self.app_running = False
        self.cap.release()
        cv2.destroyAllWindows()
        self.detector.close()
        
        print("[OK] Head Tracking uygulaması kapatıldı. Hoşça kalın!")



    def load_config(self):
        """Load configuration from JSON file"""
        file_path, _ = QFileDialog.getOpenFileName(
            self,
            'Load Config',
            str(Path.home() / 'Desktop'),
            'JSON Files (*.json);;All Files (*)'
        )
        
        if not file_path:
            return
        
        try:
            self.config_file = Path(file_path)
            with open(self.config_file, 'r') as f:
                config = json.load(f)
            
            # Load thresholds
            t = config.get('thresholds', {})
            self.sl_far_left.setValue(t.get('far_left', -12))
            self.sl_soft_left.setValue(t.get('soft_left', -7))
            self.sl_center_min.setValue(t.get('center_min', -6))
            self.sl_center_max.setValue(t.get('center_max', 6))
            self.sl_soft_right.setValue(t.get('soft_right', 12))
            self.sl_far_right.setValue(t.get('far_right', 20))
            
            # Load keys
            keys = config.get('keys', {})
            self._set_combo_by_text(self.cb_far_left, keys.get('FAR_LEFT', 'Numpad 4'))
            self._set_combo_by_text(self.cb_soft_left, keys.get('SOFT_LEFT', 'Numpad 7'))
            self._set_combo_by_text(self.cb_center, keys.get('CENTER', 'Numpad 5'))
            self._set_combo_by_text(self.cb_soft_right, keys.get('SOFT_RIGHT', 'Numpad 9'))
            self._set_combo_by_text(self.cb_far_right, keys.get('FAR_RIGHT', 'Numpad 6'))
            
            # Load others
            self.sl_smoothing.setValue(config.get('smoothing', 5))
            self.sl_tap_duration.setValue(config.get('tap_duration', 10))
            
            self.status_label.setText(f'Config loaded: {self.config_file.name}')
            QMessageBox.information(self, 'Success', f'Config loaded from:\n{self.config_file}')
        except Exception as e:
            self.status_label.setText('Config load failed')
            QMessageBox.critical(self, 'Load Error', f'Could not load config:\n{str(e)}')

    def _set_combo_by_text(self, combo, text):
        """Helper to set combobox value by text"""
        idx = combo.findText(text, Qt.MatchFlag.MatchExactly)
        if idx >= 0:
            combo.setCurrentIndex(idx)



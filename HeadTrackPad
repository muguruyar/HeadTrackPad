    def on_threshold_changed(self, _=None):
        # enforce ordering: far_left <= soft_left <= center_min <= center_max <= soft_right
        fl = self.sl_far_left.value()
        sl = max(self.sl_soft_left.value(), fl+1)
        self.sl_soft_left.blockSignals(True)
        self.sl_soft_left.setValue(sl)
        self.sl_soft_left.blockSignals(False)

        cmn = min(max(self.sl_center_min.value(), sl+1), self.sl_center_max.value()-1)
        self.sl_center_min.blockSignals(True)
        self.sl_center_min.setValue(cmn)
        self.sl_center_min.blockSignals(False)

        cmx = max(self.sl_center_max.value(), cmn+1)
        self.sl_center_max.blockSignals(True)
        self.sl_center_max.setValue(cmx)
        self.sl_center_max.blockSignals(False)

        sr = max(self.sl_soft_right.value(), cmx+1)
        self.sl_soft_right.blockSignals(True)
        self.sl_soft_right.setValue(sr)
        self.sl_soft_right.blockSignals(False)

        fr = max(self.sl_far_right.value(), sr+1)
        self.sl_far_right.blockSignals(True)
        self.sl_far_right.setValue(fr)
        self.sl_far_right.blockSignals(False)

        # Push to worker
        if self.worker:
            self.worker.update_threshold('far_left', fl)
            self.worker.update_threshold('soft_left', sl)
            self.worker.update_threshold('center_min', cmn)
            self.worker.update_threshold('center_max', cmx)
            self.worker.update_threshold('soft_right', sr)
            self.worker.update_threshold('far_right', fr)

    def on_keymap_changed(self, _=None):

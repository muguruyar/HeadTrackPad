    def hotkey_invoke(self, keyname):
        # Map actions
        if keyname == 'F1':
            # calibrate: set current yaw as center
            if self.worker:
                try:
                    self.label_yaw.setText('Yaw: 0.0°')
                    self.status_label.setText('Calibrating... keep head still for a moment')
                    self.worker.request_calibration()
                except Exception:
                    self.status_label.setText('Calibrate failed')
        elif keyname == 'F2':
            if self.worker:
                self.worker.send_keys_enabled = not self.worker.send_keys_enabled
                state = 'On' if self.worker.send_keys_enabled else 'Off'
                self.label_sendkeys.setText(f'SendKeys: {state}')
                self.status_label.setText(f'SendKeys toggled: {state}')
        elif keyname == 'F3':
            if self.worker:
                self.worker.preview_enabled = not self.worker.preview_enabled
                self.status_label.setText(f'Preview: {self.worker.preview_enabled}')
        elif keyname == 'DELETE':
            # stop and close
            self.stop_worker()
            QApplication.quit()

    def closeEvent(self, event):
        # cleanup keyboard hooks
        if keyboard is not None:
            try:
                keyboard.unhook_all()
            except Exception:

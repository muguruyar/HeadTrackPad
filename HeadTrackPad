        self.worker.update_zone_key('FAR_LEFT', self.combo_to_scan(self.cb_far_left.currentText()))
        self.worker.update_zone_key('SOFT_LEFT', self.combo_to_scan(self.cb_soft_left.currentText()))
        self.worker.update_zone_key('CENTER', self.combo_to_scan(self.cb_center.currentText()))
        self.worker.update_zone_key('SOFT_RIGHT', self.combo_to_scan(self.cb_soft_right.currentText()))
        self.worker.update_zone_key('FAR_RIGHT', self.combo_to_scan(self.cb_far_right.currentText()))

